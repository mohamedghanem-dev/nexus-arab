# .env.local — انسخ هذا الملف وسمّه .env.local وعبّي القيم الحقيقية
# لا ترفع .env.local أبداً على Git أو في أي رسالة/شات

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexusarab.com
NEXT_PUBLIC_APP_NAME=Nexus Arab

# ── Groq API Keys (4 مفاتيح — يتم اختيار واحد عشوائياً مع إعادة المحاولة عند 429) ──
# مفاتيح المساعد الذكي لا تُخزَّن أبداً في قاعدة البيانات — هنا فقط (Vercel Env Vars في الإنتاج)
GROQ_KEY_1=your_groq_key_1
GROQ_KEY_2=your_groq_key_2
GROQ_KEY_3=your_groq_key_3
GROQ_KEY_4=your_groq_key_4

# اسم الموديل — تأكد منه على https://console.groq.com/docs/models قبل النشر
# (موديلات Groq تتغير بمرور الوقت)
GROQ_MODEL=llama-3.1-8b-instant

# ── Gemini (احتياطي اختياري — غير مستخدم في route.ts الحالي) ──
GEMINI_API_KEY=your_gemini_key_here
